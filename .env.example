POSTGRES_USER=axithor
POSTGRES_PASSWORD=axithor_password
POSTGRES_DB=axithor_cloud_os
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://axithor:axithor_password@postgres:5432/axithor_cloud_os
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000
ENVIRONMENT=development
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
ACCESS_TOKEN_COOKIE_NAME=axithor_access
REFRESH_TOKEN_COOKIE_NAME=axithor_refresh
FRONTEND_BASE_URL=http://localhost:3000
BACKEND_BASE_URL=http://localhost:8000
SESSION_SECRET_KEY=replace-with-a-different-long-random-secret
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:8000/api/v1/storage/google/callback

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=Axithor Cloud OS

# Module 4 — Subdomain routing
BASE_DOMAIN=axithor.tech

# Module 7 — Cloudflare Cache (optional)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
